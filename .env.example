# ============================================================
# FormatHub — example environment variables
# Copy this file to .env and adjust values as needed.
# ============================================================

# ---------- Limits ----------
# Max size of a single uploaded file (bytes). Default: 2 GiB.
MAX_FILE_SIZE_BYTES=2147483648
# Minimum free disk space required to start an operation (bytes). Default: 500 MiB.
MIN_FREE_DISK_SPACE_BYTES=524288000

# ---------- Concurrency / queue (see TS section 2.2.8) ----------
MAX_CONCURRENT_JOBS=2
MAX_CONCURRENT_BATCH_FILES=3
MAX_BATCH_SIZE=50
MAX_WORKER_THREADS=4
JOB_TIMEOUT_MS=600000
JOB_QUEUE_MAX_PENDING=100

# ---------- Backend server ----------
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ---------- Paths to optional system binaries ----------
# Override auto-detected locations when a tool is not on PATH.
# FFMPEG_PATH=
# LIBREOFFICE_PATH=
# GHOSTSCRIPT_PATH=
# PANDOC_PATH=
# CALIBRE_PATH=
# TESSERACT_PATH=
# BLENDER_PATH=
# SEVEN_ZIP_PATH=
